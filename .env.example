# Optional — add a GitHub personal access token to include private repos.
# Scopes needed: repo (for private repos) or public_repo (for public only).
# Generate one at: https://github.com/settings/tokens
VITE_GITHUB_TOKEN=

# X (Twitter) Bearer Token — server-side only, no VITE_ prefix so it never reaches the browser.
# Generate one at: https://developer.twitter.com/en/portal/dashboard
TWITTER_BEARER_TOKEN=
